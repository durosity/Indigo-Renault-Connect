        <TriggerLabel>Plug Status</TriggerLabel>
        <TriggerLabelPrefix>Status:</TriggerLabelPrefix>
        <ControlPageLabel>Plug Status Changed</ControlPageLabel>
        <ConfigUI>
            <Field id="device" type="menu">
                <Label>Vehicle:</Label>
                <List class="self" filter="self.renaultVehicle" method="getDeviceList"/>
            </Field>
            <Field id="separator1" type="separator"/>
            <Field id="plugCondition" type="menu" defaultValue="any">
                <Label>Trigger When:</Label>
                <List>
                    <Option value="any">Any Plug Change</Option>
                    <Option value="plugged">Plugged In</Option>
                    <Option value="unplugged">Unplugged</Option>
                </List>
            </Field>
        </ConfigUI>
    </Event>

    <!-- HVAC Status Changed Event -->
    <Event id="hvacStatusChanged">
        <n>HVAC Status Changed</n>
        <TriggerLabel>HVAC Status</TriggerLabel>
        <TriggerLabelPrefix>HVAC:</TriggerLabelPrefix>
        <ControlPageLabel>HVAC Status Changed</ControlPageLabel>
        <ConfigUI>
            <Field id="device" type="menu">
                <Label>Vehicle:</Label>
                <List class="self" filter="self.renaultVehicle" method="getDeviceList"/>
            </Field>
            <Field id="separator1" type="separator"/>
            <Field id="hvacCondition" type="menu" defaultValue="any">
                <Label>Trigger When:</Label>
                <List>
                    <Option value="any">Any HVAC Change</Option>
                    <Option value="on">HVAC Turned On</Option>
                    <Option value="off">HVAC Turned Off</Option>
                </List>
            </Field>
        </ConfigUI>
    </Event>

    <!-- Charging Power Changed Event -->
    <Event id="chargingPowerChanged">
        <n>Charging Power Changed</n>
        <TriggerLabel>Charging Power</TriggerLabel>
        <TriggerLabelPrefix>Power:</TriggerLabelPrefix>
        <ControlPageLabel>Charging Power Changed</ControlPageLabel>
        <ConfigUI>
            <Field id="device" type="menu">
                <Label>Vehicle:</Label>
                <List class="self" filter="self.renaultVehicle" method="getDeviceList"/>
            </Field>
            <Field id="separator1" type="separator"/>
            <Field id="powerCondition" type="menu" defaultValue="any">
                <Label>Trigger When:</Label>
                <List>
                    <Option value="any">Any Power Change</Option>
