                    <Option value="below">Power Below (kW)</Option>
                    <Option value="zero">Power Drops to Zero</Option>
                    <Option value="nonzero">Power Becomes Non-Zero</Option>
                </List>
            </Field>
            <Field id="powerValue" type="textfield" defaultValue="5" visibleBindingId="powerCondition" visibleBindingValue="above,below">
                <Label>Power (kW):</Label>
            </Field>
        </ConfigUI>
    </Event>
</Events>
